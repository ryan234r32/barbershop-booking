{
  "name": "barbershop-booking",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build --webpack",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "preflight": "npm run typecheck && npm run lint && npm run test",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:excel:dryrun": "npx tsx scripts/import-historical-excel.ts",
    "import:excel": "npx tsx scripts/import-historical-excel.ts --commit",
    "import:excel:reset": "npx tsx scripts/import-historical-excel.ts --commit --reset",
    "cleanup:dryrun": "npx tsx scripts/clean-test-data.ts",
    "cleanup:execute": "npx tsx scripts/clean-test-data.ts --commit",
    "reports:snapshot": "npx tsx scripts/generate-reports-snapshot.ts",
    "rich-menu:upload": "npx tsx scripts/upload-rich-menu.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@line/bot-sdk": "^10.6.0",
    "@line/liff": "^2.27.3",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@sentry/nextjs": "^10.51.0",
    "@serwist/next": "^9.5.7",
    "@supabase/supabase-js": "^2.99.3",
    "@types/web-push": "^3.6.4",
    "@upstash/lock": "^0.2.1",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ecpay_aio_nodejs": "^1.2.2",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "serwist": "^9.5.7",
    "shadcn": "^4.6.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "overrides": {
    "axios": ">=1.15.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "knip": "^6.11.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
