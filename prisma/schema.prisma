generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// MULTI-TENANT CORE
// ============================================

model Tenant {
  id                String     @id @default(uuid())
  name              String
  slug              String     @unique
  lineChannelId     String     @unique @map("line_channel_id")
  lineChannelSecret String     @map("line_channel_secret")
  lineAccessToken   String     @map("line_access_token")
  liffId            String     @map("liff_id")

  businessName      String     @map("business_name")
  phone             String?
  address           String?
  bankInfo          String?    @map("bank_info")
  bankAccountName   String?    @map("bank_account_name")
  bankAccountNumber String?    @map("bank_account_number")

  plan              TenantPlan @default(TRIAL)
  trialEndsAt       DateTime?  @map("trial_ends_at")
  subscriptionEndsAt DateTime? @map("subscription_ends_at")

  isActive          Boolean    @default(true) @map("is_active")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  users             User[]
  services          Service[]
  bookings          Booking[]
  businessHours     BusinessHours[]
  holidays          Holiday[]
  adminUsers        AdminUser[]
  notifications     Notification[]
  messages          Message[]

  quickReplies      Json?              @map("quick_replies")

  @@map("tenants")
}

enum TenantPlan {
  TRIAL
  BASIC
  STANDARD
  PREMIUM
}

// ============================================
// ADMIN USERS
// ============================================

model AdminUser {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  email     String
  password  String
  name      String
  role      AdminRole @default(OWNER)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  pushSubscriptions PushSubscription[]

  @@unique([tenantId, email])
  @@map("admin_users")
}

/// Web Push subscription for a PWA device an admin has opted in.
/// endpoint is the natural dedup key — each device's FCM/APNs URL is unique.
/// failureCount + lastFailedAt track transient failures; 410/404/401 auto-delete
/// (see sendWebPushToAdmin in src/lib/push/web-push.ts).
model PushSubscription {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  adminUserId  String    @map("admin_user_id")
  endpoint     String    @unique
  p256dh       String
  auth         String
  userAgent    String?   @map("user_agent")
  failureCount Int       @default(0) @map("failure_count")
  lastFailedAt DateTime? @map("last_failed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([adminUserId])
  @@map("push_subscriptions")
}

enum AdminRole {
  OWNER
  STAFF
}

// ============================================
// CUSTOMERS (LINE USERS)
// ============================================

model User {
  id                String          @id @default(uuid())
  tenantId          String          @map("tenant_id")
  lineUserId        String          @map("line_user_id")

  displayName       String?         @map("display_name")
  pictureUrl        String?         @map("picture_url")

  phone             String?
  realName          String?         @map("real_name")
  email             String?

  segment           CustomerSegment @default(NEW)
  isVip             Boolean         @default(false) @map("is_vip")

  violationCount    Int             @default(0) @map("violation_count")
  violationResetAt  DateTime?       @map("violation_reset_at")
  bookingRestricted Boolean         @default(false) @map("booking_restricted")
  restrictedUntil   DateTime?       @map("restricted_until")

  totalVisits       Int             @default(0) @map("total_visits")
  lastVisitAt       DateTime?       @map("last_visit_at")
  firstVisitAt      DateTime?       @map("first_visit_at")

  birthday          DateTime?       @db.Date @map("birthday")
  birthdayMonth     Int?            @map("birthday_month")
  birthdayDay       Int?            @map("birthday_day")

  notes             String?
  tags              String[]        @default([])
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  bookings          Booking[]
  cancellationRecords CancellationRecord[]
  messages          Message[]

  @@unique([tenantId, lineUserId])
  @@index([tenantId, segment])
  @@index([tenantId, lastVisitAt])
  @@index([tenantId, birthdayMonth, birthdayDay])
  @@map("users")
}

enum CustomerSegment {
  NEW
  REGULAR
  VIP
  AT_RISK
  LAPSED
  BLACKLISTED
}

// ============================================
// SERVICES
// ============================================

model Service {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  imageUrl    String?  @map("image_url")
  duration    Int
  slotsNeeded Int      @map("slots_needed")
  price       Int
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  bookings    Booking[]

  @@unique([tenantId, name], name: "tenantId_name")
  @@index([tenantId, isActive])
  @@map("services")
}

// ============================================
// BUSINESS HOURS & HOLIDAYS
// ============================================

model BusinessHours {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  dayOfWeek Int
  startTime String  @map("start_time")
  endTime   String  @map("end_time")
  isOpen    Boolean @default(true) @map("is_open")

  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, dayOfWeek])
  @@map("business_hours")
}

model Holiday {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId, date])
  @@map("holidays")
}

// ============================================
// BOOKINGS
// ============================================

model Booking {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  userId        String        @map("user_id")
  serviceId     String        @map("service_id")

  date          DateTime      @db.Date
  startTime     String        @map("start_time")
  endTime       String        @map("end_time")
  slotsOccupied Int           @map("slots_occupied")

  status        BookingStatus @default(CONFIRMED)
  source        BookingSource @default(LIFF)
  notes         String?

  lateRescheduleCount Int     @default(0) @map("late_reschedule_count")

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  service       Service       @relation(fields: [serviceId], references: [id])
  payment       Payment?
  cancellation  CancellationRecord?
  notifications Notification[]

  @@index([tenantId, date, status])
  @@index([tenantId, userId])
  @@index([tenantId, date, startTime])
  @@map("bookings")
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  CANCELLED_BY_ADMIN
}

enum BookingSource {
  LIFF
  PHONE
  WALK_IN
  ADMIN
}

// ============================================
// CANCELLATION RECORDS
// ============================================

model CancellationRecord {
  id          String   @id @default(uuid())
  bookingId   String   @unique @map("booking_id")
  userId      String   @map("user_id")

  cancelledAt DateTime @default(now()) @map("cancelled_at")
  isViolation Boolean  @default(false) @map("is_violation")
  reason      String?

  bookingDate DateTime @db.Date @map("booking_date")
  bookingTime String   @map("booking_time")

  booking     Booking  @relation(fields: [bookingId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, isViolation])
  @@map("cancellation_records")
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique @map("booking_id")

  amount        Int
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(PENDING)

  screenshotUrl String?       @map("screenshot_url")
  receivedAt    DateTime?     @map("received_at")
  notes         String?

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  booking       Booking       @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  RECEIVED
  WAIVED
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id             String             @id @default(uuid())
  tenantId       String             @map("tenant_id")
  bookingId      String?            @map("booking_id")

  type           NotificationType
  scheduledAt    DateTime           @map("scheduled_at")
  sentAt         DateTime?          @map("sent_at")
  status         NotificationStatus @default(PENDING)

  lineUserId     String             @map("line_user_id")
  messagePayload Json?              @map("message_payload")
  errorMessage   String?            @map("error_message")

  createdAt      DateTime           @default(now()) @map("created_at")

  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  booking        Booking?           @relation(fields: [bookingId], references: [id])

  @@index([status, scheduledAt])
  @@index([tenantId, type])
  @@map("notifications")
}

enum NotificationType {
  BOOKING_CONFIRMATION
  REMINDER_24H
  REMINDER_2H
  REMINDER_1H
  CANCELLATION_CONFIRMATION
  WELCOME
  THANK_YOU
  FOLLOW_UP_7D
  BIRTHDAY_GREETING
  CUSTOM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

// ============================================
// MESSAGES (LINE Chat Inbox)
// ============================================

model Message {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  userId          String?          @map("user_id")
  lineUserId      String           @map("line_user_id")
  lineMessageId   String?          @map("line_message_id")
  clientMessageId String?          @map("client_message_id")
  direction       MessageDirection
  type            MessageType
  kind            MessageKind      @default(STANDARD)
  content         String?          @db.Text

  // raw: LINE event payload. Debug/sticker metadata only.
  // Do NOT query into this column (no JSON where clauses); add a dedicated
  // column if a new query need emerges.
  raw             Json?

  isRead          Boolean          @default(false) @map("is_read")
  createdAt       DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@unique([lineUserId, lineMessageId])
  @@unique([tenantId, clientMessageId])
  @@index([tenantId, lineUserId, createdAt(sort: Desc)])
  @@index([tenantId, isRead])
  @@index([tenantId, lineUserId, kind, createdAt(sort: Desc)])
  @@map("messages")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  STICKER
  IMAGE
  VIDEO
  AUDIO
  LOCATION
  FILE
  OTHER
}

enum MessageKind {
  STANDARD
  BUSY_NOTICE
  WELCOME
  KEYWORD_REPLY
}
