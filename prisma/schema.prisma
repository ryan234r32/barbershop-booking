generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// MULTI-TENANT CORE
// ============================================

model Tenant {
  id                String @id @default(uuid())
  name              String
  slug              String @unique
  lineChannelId     String @unique @map("line_channel_id")
  lineChannelSecret String @map("line_channel_secret")
  lineAccessToken   String @map("line_access_token")
  liffId            String @map("liff_id")

  businessName      String  @map("business_name")
  phone             String?
  address           String?
  bankInfo          String? @map("bank_info")
  bankAccountName   String? @map("bank_account_name")
  bankAccountNumber String? @map("bank_account_number")

  plan               TenantPlan @default(TRIAL)
  trialEndsAt        DateTime?  @map("trial_ends_at")
  subscriptionEndsAt DateTime?  @map("subscription_ends_at")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                 User[]
  services              Service[]
  bookings              Booking[]
  businessHours         BusinessHours[]
  holidays              Holiday[]
  adminUsers            AdminUser[]
  notifications         Notification[]
  messages              Message[]
  consultationRequests  ConsultationRequest[]
  coupons               Coupon[]
  feedbacks             Feedback[]  /// V3.7 Tier 1.7
  expenses              Expense[]
  expenseRecurringRules ExpenseRecurringRule[]
  dailyCloseSnapshots   DailyCloseSnapshot[]

  quickReplies Json? @map("quick_replies")

  /// Per-tenant feature toggles. Known keys (PRD-v3 §8 Wave 2c+):
  /// - couponAbTest: boolean — master switch for the 30d-vs-45d A/B
  /// - couponStrategyAOnly: boolean — emergency: force everyone to A arm
  /// - couponStrategyBOnly: boolean — emergency: force everyone to B arm
  /// Add new keys via PR with this comment block updated.
  featureFlags Json? @default("{}") @map("feature_flags")

  /// V3.6 §4.2 — monthly revenue targets. Key = "YYYY-MM", value = revenue (TWD).
  /// e.g. {"2026-01": 140000, "2026-02": 130000}.
  /// Set via /api/admin/year-target (annual radio scenarios) or /reports monthly footer.
  monthlyTargets Json? @map("monthly_targets")

  /// V3.6 §7.3 — year target metadata: {year, scenario, targetAnnualRevenue, monthlyTargets}.
  /// scenario ∈ "conservative" | "flat" | "aggressive" | "custom".
  yearTargets Json? @map("year_targets")

  /// V3.6 §5.2 — daily settlement lock. Key = ISO yyyy-mm-dd, value = closing time ISO string.
  /// Once a date is keyed here the daily view UI marks it "已結班" + read-only.
  dayClosedAt Json? @map("day_closed_at")

  @@map("tenants")
}

enum TenantPlan {
  TRIAL
  BASIC
  STANDARD
  PREMIUM
}

// ============================================
// ADMIN USERS
// ============================================

model AdminUser {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  email     String
  password  String
  name      String
  role      AdminRole @default(OWNER)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  pushSubscriptions PushSubscription[]

  @@unique([tenantId, email])
  @@map("admin_users")
}

/// Web Push subscription for a PWA device an admin has opted in.
/// endpoint is the natural dedup key — each device's FCM/APNs URL is unique.
/// failureCount + lastFailedAt track transient failures; 410/404/401 auto-delete
/// (see sendWebPushToAdmin in src/lib/push/web-push.ts).
model PushSubscription {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  adminUserId  String    @map("admin_user_id")
  endpoint     String    @unique
  p256dh       String
  auth         String
  userAgent    String?   @map("user_agent")
  failureCount Int       @default(0) @map("failure_count")
  lastFailedAt DateTime? @map("last_failed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([adminUserId])
  @@map("push_subscriptions")
}

enum AdminRole {
  OWNER
  STAFF
}

// ============================================
// CUSTOMERS (LINE USERS)
// ============================================

model User {
  id         String @id @default(uuid())
  tenantId   String @map("tenant_id")
  lineUserId String @map("line_user_id")

  displayName String? @map("display_name")
  pictureUrl  String? @map("picture_url")

  phone    String?
  realName String? @map("real_name")
  email    String?
  gender   Gender?

  segment CustomerSegment @default(NEW)
  isVip   Boolean         @default(false) @map("is_vip")

  violationCount    Int       @default(0) @map("violation_count")
  violationResetAt  DateTime? @map("violation_reset_at")
  bookingRestricted Boolean   @default(false) @map("booking_restricted")
  restrictedUntil   DateTime? @map("restricted_until")

  totalVisits  Int       @default(0) @map("total_visits")
  lastVisitAt  DateTime? @map("last_visit_at")
  firstVisitAt DateTime? @map("first_visit_at")

  /// Set the first time the customer self-fills their phone via LIFF /profile.
  /// Drives the launch lottery eligibility (only entries within window qualify).
  /// Never set by admin manual edits — only by /api/profile/me.
  profileCompletedAt DateTime? @map("profile_completed_at")

  birthday      DateTime? @map("birthday") @db.Date
  birthdayMonth Int?      @map("birthday_month")
  birthdayDay   Int?      @map("birthday_day")

  notes String?
  tags  String[] @default([])

  /// V3.6 §14.5 — 客戶可在 LIFF 設定頁關閉行銷推播，cron retention-push 會跳過此客戶。
  /// 此旗標**不影響**預約確認 / 提醒等交易性 LINE 推播。
  marketingOptOut Boolean @default(false) @map("marketing_opt_out")

  /// V3.7 Tier 1.8 — 熟客自動帶折扣金額（NT$；正值 = 結帳時自動扣）。
  /// NULL = 一般客（無自動折扣）。Admin 在結帳頁點「設為熟客」按鈕設定。
  /// 老闆規則：「我自己扣這樣自己記得」彈性比較大 — 故 ad-hoc 金額，
  /// 非階梯式會員價（V3 範圍不做複雜會員等級）。詳見訪談 §六 折扣處理。
  defaultDiscount   Int?      @map("default_discount")
  discountSetAt     DateTime? @map("discount_set_at")
  discountSetBy     String?   @map("discount_set_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  bookings             Booking[]
  cancellationRecords  CancellationRecord[]
  messages             Message[]
  consultationRequests ConsultationRequest[]
  coupons              Coupon[]
  feedbacks            Feedback[]  /// V3.7 Tier 1.7

  @@unique([tenantId, lineUserId])
  @@index([tenantId, segment])
  @@index([tenantId, lastVisitAt])
  @@index([tenantId, birthdayMonth, birthdayDay])
  @@map("users")
}

enum CustomerSegment {
  NEW
  REGULAR
  VIP
  AT_RISK
  LAPSED
  BLACKLISTED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ============================================
// SERVICES
// ============================================

model Service {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  imageUrl    String?  @map("image_url")
  duration    Int
  slotsNeeded Int      @map("slots_needed")
  price       Int
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  bookings             Booking[]
  bookingServices      BookingService[]      /// V3.7 Tier 0.2 multi-service reverse relation
  consultationRequests ConsultationRequest[]

  @@unique([tenantId, name], name: "tenantId_name")
  @@index([tenantId, isActive])
  @@map("services")
}

// ============================================
// BUSINESS HOURS & HOLIDAYS
// ============================================

model BusinessHours {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  dayOfWeek Int
  startTime String  @map("start_time")
  endTime   String  @map("end_time")
  isOpen    Boolean @default(true) @map("is_open")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, dayOfWeek])
  @@map("business_hours")
}

/// V3.7 P1-3 — Holiday supports partial-day closure via optional time range.
/// `startTime` / `endTime` are "HH:00" strings (matches BusinessHours grain).
/// Both NULL → full-day closure (existing behaviour, no migration needed).
/// Both set → only those slots are blocked; other slots remain bookable.
/// Half-set is invalid: API rejects, schema kept loose so backfill stays safe.
model Holiday {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  date      DateTime @db.Date
  startTime String?  @map("start_time")
  endTime   String?  @map("end_time")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId, date])
  @@map("holidays")
}

// ============================================
// BOOKINGS
// ============================================

model Booking {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  userId    String @map("user_id")
  serviceId String @map("service_id")

  date          DateTime @db.Date
  startTime     String   @map("start_time")
  endTime       String   @map("end_time")
  slotsOccupied Int      @map("slots_occupied")

  status BookingStatus @default(CONFIRMED)
  source BookingSource @default(LIFF)
  notes  String?

  lateRescheduleCount Int @default(0) @map("late_reschedule_count")

  /// When the shop owner clicked "I've seen this" in the unacknowledged-bookings
  /// queue (or by opening the BookingDetailSheet from a notification). NULL means
  /// the admin hasn't confirmed awareness yet — used to drive the queue modal in
  /// /calendar. Idempotent: re-acking does nothing. See UnacknowledgedModal +
  /// /api/bookings/unacknowledged.
  adminAcknowledgedAt DateTime? @map("admin_acknowledged_at")

  /// V3.5 夯客流程：admin 手動點「已報到」的時間戳。
  /// NULL = 尚未到來；NOT NULL = 已報到。
  /// 「爽約」走 status = NO_SHOW 路徑，不寫此欄。
  /// COMPLETED booking 一定有此值（結帳前若仍 NULL 自動補 now()）。
  /// 既有 COMPLETED 資料無 checkedInAt — 視為「已報到 + 已結帳」grandfather。
  checkedInAt DateTime? @map("checked_in_at")

  /// V3.6 §5.2 — 老闆對帳時間戳：daily view 「確認」按鈕觸發。
  /// NULL = 待對帳；NOT NULL = 已對帳。
  /// 結班按鈕需要當日所有 COMPLETED booking 都有此值才解鎖。
  settledAt DateTime? @map("settled_at")

  /// V3.6 §4.1 — 離店再預約標記：客戶結帳當下若 admin 在 0-2 小時內為其建立未來 Booking → true.
  /// 用於計算 prebookRate（業界第一武器留客指標）。
  /// 預設 false；admin /api/bookings POST + ?prebookSource=true 時設為 true。
  prebookSource Boolean @default(false) @map("prebook_source")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant                    Tenant               @relation(fields: [tenantId], references: [id])
  user                      User                 @relation(fields: [userId], references: [id])
  service                   Service              @relation(fields: [serviceId], references: [id])
  payment                   Payment?
  ecpayOrders               ECPayOrder[]
  cancellation              CancellationRecord?
  notifications             Notification[]
  convertedFromConsultation ConsultationRequest? @relation("ConvertedFromConsultation")

  /// V3.7 Tier 0.2 — 服務多選擴充。
  /// 過渡期：legacy `serviceId` 仍是 source of truth；新增的 `services` 是 dual-write
  /// destination。讀取邏輯：prefer `services[]`（若 non-empty）→ fallback `service`
  /// (singular). 詳見 docs/v3.7-pre-launch-readiness-plan.md §0a E-A。
  /// Backfill script: scripts/backfill-booking-services.ts。
  services                  BookingService[]
  /// V3.7 Tier 1.7 — 客戶結帳完成後可選填 NPS + 2 開放題
  feedback                  Feedback?

  @@index([tenantId, date, status])
  @@index([tenantId, userId])
  @@index([tenantId, date, startTime])
  @@index([tenantId, status, adminAcknowledgedAt])
  /// PRD-v3 §5 + E-10: covers CRM segmentation CTE (filter by status+date, GROUP BY userId).
  @@index([tenantId, userId, status, date])
  @@map("bookings")
}

// ============================================
// BOOKING SERVICES (V3.7 Tier 0.2 multi-service support)
// ============================================

/// V3.7 Tier 0.2 §0a E-A — 一筆預約可選多服務（剪+染+護等）。
/// Dual-read/dual-write 過渡期：legacy `Booking.serviceId` 仍保留為主要 FK，
/// `BookingService[]` 是新管道。讀取時 prefer `services[]`，empty 才 fallback。
/// OCC: 寫 BookingService 時必須同 transaction bump 父 Booking.updatedAt（child
/// 不會自動 bump parent）— 詳見 §0a E-B。
model BookingService {
  id          String   @id @default(uuid())
  bookingId   String   @map("booking_id")
  serviceId   String   @map("service_id")
  /// 服務順序（0 = 主服務、對應 legacy Booking.serviceId）
  order       Int      @default(0)
  /// 該服務當下價格（snapshot — 服務原價 if not overridden）
  price       Int
  /// 該服務時數（HH grain；0.5hr 拆分待 Tier 1.4 admin-only support）
  durationMin Int      @map("duration_min")
  createdAt   DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([bookingId])
  @@index([serviceId])
  @@map("booking_services")
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  CANCELLED_BY_ADMIN
}

enum BookingSource {
  LIFF
  PHONE
  WALK_IN
  ADMIN
}

// ============================================
// CANCELLATION RECORDS
// ============================================

model CancellationRecord {
  id        String @id @default(uuid())
  bookingId String @unique @map("booking_id")
  userId    String @map("user_id")

  cancelledAt DateTime @default(now()) @map("cancelled_at")
  isViolation Boolean  @default(false) @map("is_violation")
  reason      String?

  bookingDate DateTime @map("booking_date") @db.Date
  bookingTime String   @map("booking_time")

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId, isViolation])
  @@map("cancellation_records")
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id        String @id @default(uuid())
  bookingId String @unique @map("booking_id")

  amount Int
  method PaymentMethod @default(CASH)
  status PaymentStatus @default(PENDING)

  // 轉帳對帳：客戶回報的轉出帳號末 5 碼
  transferLastFive String?   @map("transfer_last_five")
  // 客戶回報末五碼的時間（進入 VERIFYING 狀態的時間戳）
  verifiedAt       DateTime? @map("verified_at")

  /// @deprecated 2026-04 末五碼對帳取代；僅保留舊資料，新流程不寫入
  screenshotUrl String?   @map("screenshot_url")
  receivedAt    DateTime? @map("received_at")
  notes         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  booking     Booking      @relation(fields: [bookingId], references: [id])
  ecpayOrders ECPayOrder[]

  @@index([status, verifiedAt])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  ECPAY_ATM // Tier S：綠界虛擬帳號
}

enum PaymentStatus {
  PENDING // 待付款：客戶尚未回報
  AWAITING_BANK // Tier S：虛擬帳號已產生，等待客戶匯款入帳
  VERIFYING // 待對帳：客戶已回報末五碼，等老闆確認
  RECEIVED // 已收款
  WAIVED // 免收（admin 豁免）
  EXPIRED // Tier S：虛擬帳號過期未入帳
}

// Tier S：綠界 ECPay 訂單記錄
// 一個 Payment 可能有多筆 ECPayOrder（重試時舊的標 FAILED，新的建立）
// 併發控制：create-order handler 使用 Redis lock `ecpay:create:{bookingId}`
model ECPayOrder {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  bookingId String @map("booking_id")
  paymentId String @map("payment_id")

  // 我們送給綠界的訂單號（20 碼英數、全域 unique）
  merchantTradeNo   String  @unique @map("merchant_trade_no")
  // 綠界要求格式 yyyy/MM/dd HH:mm:ss（台灣時間）
  merchantTradeDate String  @map("merchant_trade_date")
  // 綠界回傳的交易編號（PaymentInfo webhook 或 Return webhook 才有）
  tradeNo           String? @map("trade_no")

  amount     Int
  bankCode   String?   @map("bank_code") // 虛擬帳號銀行代碼，例 "008"
  vAccount   String?   @map("v_account") // 虛擬帳號
  expireDate DateTime? @map("expire_date") // 虛擬帳號過期時間

  status            ECPayOrderStatus @default(CREATED)
  rawCreateResponse Json?            @map("raw_create_response") // 綠界建單回應
  rawPaymentInfo    Json?            @map("raw_payment_info") // PaymentInfoURL webhook payload
  rawReturn         Json?            @map("raw_return") // ReturnURL webhook payload
  failureReason     String?          @map("failure_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([tenantId, status])
  @@index([bookingId])
  @@index([paymentId])
  @@index([expireDate, status])
  @@map("ecpay_orders")
}

enum ECPayOrderStatus {
  CREATED // DB 已 insert，尚未呼叫 ECPay
  PENDING // ECPay 已產生虛擬帳號，等客戶匯款
  PAID // 入帳 webhook 確認
  EXPIRED // 逾期未付（cron 標記）
  FAILED // ECPay 建單失敗 / timeout / amount mismatch
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  bookingId String? @map("booking_id")

  type        NotificationType
  scheduledAt DateTime           @map("scheduled_at")
  sentAt      DateTime?          @map("sent_at")
  status      NotificationStatus @default(PENDING)

  lineUserId     String  @map("line_user_id")
  messagePayload Json?   @map("message_payload")
  errorMessage   String? @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([status, scheduledAt])
  @@index([tenantId, type])
  @@map("notifications")
}

enum NotificationType {
  BOOKING_CONFIRMATION
  REMINDER_24H
  REMINDER_2H
  REMINDER_1H
  CANCELLATION_CONFIRMATION
  WELCOME
  THANK_YOU
  FOLLOW_UP_7D
  BIRTHDAY_GREETING
  CUSTOM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

// ============================================
// MESSAGES (LINE Chat Inbox)
// ============================================

model Message {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  userId          String?          @map("user_id")
  lineUserId      String           @map("line_user_id")
  lineMessageId   String?          @map("line_message_id")
  clientMessageId String?          @map("client_message_id")
  direction       MessageDirection
  type            MessageType
  kind            MessageKind      @default(STANDARD)
  content         String?          @db.Text

  // raw: LINE event payload. Debug/sticker metadata only.
  // Do NOT query into this column (no JSON where clauses); add a dedicated
  // column if a new query need emerges.
  raw Json?

  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@unique([lineUserId, lineMessageId])
  @@unique([tenantId, clientMessageId])
  @@index([tenantId, lineUserId, createdAt(sort: Desc)])
  @@index([tenantId, isRead])
  @@index([tenantId, lineUserId, kind, createdAt(sort: Desc)])
  @@map("messages")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  STICKER
  IMAGE
  VIDEO
  AUDIO
  LOCATION
  FILE
  OTHER
}

enum MessageKind {
  STANDARD
  BUSY_NOTICE
  WELCOME
  KEYWORD_REPLY
}

// ============================================
// CONSULTATION REQUESTS (PRD-v3 §3, Wave 2b)
// ============================================
//
// Customers ask about 漂髮 (bleach) or first-time-as-of-45-days don't get a
// Booking — they get a ConsultationRequest. Admin reviews the photos / notes
// / target style, then either replies via LINE or converts to a Booking using
// the standard ack flow.
//
// Routes / UI live in Wave 4a (consultation-flow). This Wave 2b PR is schema
// additive only — zero risk to existing flows.
model ConsultationRequest {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  userId     String? @map("user_id")
  lineUserId String  @map("line_user_id")
  serviceId  String? @map("service_id")

  // Customer-submitted content
  currentPhotoUrls String[]  @default([]) @map("current_photo_urls")
  targetPhotoUrls  String[]  @default([]) @map("target_photo_urls")
  lastServiceDate  DateTime? @map("last_service_date") @db.Date
  notes            String?

  status   ConsultationStatus @default(PENDING)
  priority Int                @default(0) // manual bump to top of queue

  respondedAt        DateTime? @map("responded_at")
  convertedBookingId String?   @unique @map("converted_booking_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  user             User?    @relation(fields: [userId], references: [id])
  service          Service? @relation(fields: [serviceId], references: [id])
  convertedBooking Booking? @relation("ConvertedFromConsultation", fields: [convertedBookingId], references: [id])

  @@index([tenantId, status, priority])
  @@index([lineUserId])
  @@map("consultation_requests")
}

enum ConsultationStatus {
  PENDING // 等老闆回
  REPLIED // 已回覆，未轉預約
  CONVERTED // 已轉預約
  ARCHIVED // 忽略 / 失效
}

// ============================================
// COUPONS — Repurchase A/B test (PRD-v3 §8, Wave 2c)
// ============================================
//
// On Booking COMPLETED, if tenant.featureFlags.couponAbTest is true, issue a
// coupon to the customer with one of two strategies:
//   - STRATEGY_A_30D_95OFF: 30-day expiry (urgency-driven)
//   - STRATEGY_B_45D_95OFF: 45-day expiry (haircut-cycle-aligned)
//
// Both 5% off (95 折). Single variable (expiry length) — A/B comparable.
// Arm assignment is deterministic via userId hashCode % 2 (stable per user).
//
// Routes / cron / LIFF page live in Wave 4c (coupon-ab). This Wave 2c PR is
// schema additive only — no behavior change until tenant flag flipped.
model Coupon {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")
  code     String @unique // human-friendly redeem code, generated at issue time

  type          CouponType
  discountPct   Int        @default(5) // 95 折 = 5% off
  experimentArm String?    @map("experiment_arm") // "A" or "B" — for A/B analytics

  issuedAt         DateTime  @default(now()) @map("issued_at")
  expiresAt        DateTime  @map("expires_at")
  usedAt           DateTime? @map("used_at")
  usedForBookingId String?   @map("used_for_booking_id")

  issuedReason CouponReason @default(BOOKING_COMPLETED) @map("issued_reason")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, usedAt])
  @@index([expiresAt, usedAt])
  @@index([experimentArm, issuedAt])
  @@map("coupons")
}

/// V3.7 Tier 1.7 (autoplan E-I) — 新客 B 組 (B_FEEDBACK_8OFF) 填問卷 → 升 8 折。
/// 也支援所有客戶 NPS 持續追蹤（業界 retention 標準指標）。
/// Linked 1:1 with booking (filed AFTER 結帳完成)。
model Feedback {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  bookingId String   @unique @map("booking_id") // 一次預約一份回饋

  /// NPS：0-10「您願意推薦給朋友的程度？」業界標準 retention 指標。
  nps Int?

  /// 自由文字：「今天剪髮最滿意的地方？」(訪談 §九 老闆認可的問題 1)
  satisfied String?
  /// 自由文字：「最可能需要改善的地方？」(問題 2)
  improvement String?

  /// 是否觸發了 B 組券升級（填完 = true → 自動發 B_FEEDBACK_8OFF）
  upgradedToB Boolean @default(false) @map("upgraded_to_b")

  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([nps]) // for monthly NPS aggregation
  @@map("feedbacks")
}

enum CouponType {
  STRATEGY_A_30D_95OFF
  STRATEGY_B_45D_95OFF
  /// V3.7 Tier 1.7 (autoplan F2/E-I) — 新增 A/B/C 對照組券種。
  /// 第一次剪完當下發券；A 50% / B 30% / C 20%（對照組不發 → 用 CouponInstance
  /// 留 issued log 但 type 不發實體券）。詳見 docs/v3.7-pre-launch-readiness-plan.md §0a E-I。
  A_9OFF
  B_FEEDBACK_8OFF
  C_CONTROL
  MANUAL
  CAMPAIGN
}

enum CouponReason {
  BOOKING_COMPLETED
  MANUAL
  CAMPAIGN
  RETENTION_DISCOUNT // V3.6 Phase H：服務分群 49 天到期券
  RETENTION_WINBACK // V3.6 Phase H：服務分群 70+ 天召回券
}

// ============================================
// V3.6 PHASE H — RETENTION PUSH SCHEDULE (服務分群自動推播)
// ============================================
//
// Each row = one customer × one service-stage push that's scheduled / sent.
// Cron job /api/cron/retention-push (10:00 Taipei) iterates RETENTION_RULES,
// picks customers, and writes one PushSchedule row per (customer, service, stage).
//
// stage encodes BOTH the trigger day AND the message tone:
//   - SOFT_REMINDER (剪 35 / 染 31 / 燙 90 days since last service)
//   - DISCOUNT_10 (剪 49 / 染 56 / 燙 120 days)
//   - WINBACK (剪 70 / 染 90 / 燙 150 days)
//
// Anti-spam: cooldown checked via PushSchedule rows in the past 7 days for
// the same userId. couponId set when stage emits a coupon.
//
// See V3.6 plan §14.4 for cron logic, §14.5 for anti-spam rules.
model PushSchedule {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  serviceCategory String     @map("service_category") // "剪髮" | "染髮" | "燙髮"
  stage           PushStage
  scheduledFor    DateTime   @map("scheduled_for")
  status          PushStatus @default(QUEUED)

  // Coupon emitted with this push (DISCOUNT_10 + WINBACK stages only)
  couponId String? @unique @map("coupon_id")

  // For tracking effectiveness — when was the customer's *next* booking after
  // receiving this push (filled by post-booking observer if within 30 days)
  convertedBookingId String?   @map("converted_booking_id")
  convertedAt        DateTime? @map("converted_at")

  sentAt       DateTime? @map("sent_at")
  errorMessage String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, stage, sentAt])
  @@map("push_schedules")
}

enum PushStage {
  SOFT_REMINDER
  DISCOUNT_10
  WINBACK
}

enum PushStatus {
  QUEUED // 已建立尚未送達
  SENT // 已送出
  SKIPPED // 因死忠客排除 / cooldown / 全店上限被跳過
  FAILED // LINE push API 失敗
}

// ============================================
// V3.7 — EXPENSES (固定 / 變動支出)
// ============================================

/// V3.7 §1 — single-shop expense ledger. One row per actual paid expense.
/// Recurring expenses materialise into rows via /api/cron/recurring-expenses.
model Expense {
  id       String   @id @default(uuid())
  tenantId String   @map("tenant_id")
  date     DateTime @db.Date

  amount     Int // 整數 NTD（與 Booking/Payment.amount 一致）
  category   String // 'consumables' | 'utilities' | 'rent' | 'equipment' | 'cleaning' | 'marketing' | 'tax' | 'other'
  type       ExpenseType
  paidMethod ExpensePaidMethod @default(CASH) @map("paid_method")
  notes      String?
  receiptUrl String?           @map("receipt_url") // Vercel Blob URL（V1 不上 OCR）

  /// 若由定期規則產生，FK 至 ExpenseRecurringRule。一次性支出此欄為 null。
  recurringRuleId String? @map("recurring_rule_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  recurringRule ExpenseRecurringRule? @relation(fields: [recurringRuleId], references: [id])

  @@index([tenantId, date])
  @@index([tenantId, type, date])
  @@map("expenses")
}

/// V3.7 §2 — recurring expense template. Cron walks this table daily and
/// inserts an Expense row when today.day === dayOfMonth & active.
model ExpenseRecurringRule {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  name       String // "房租"、"水電費"
  amount     Int
  category   String
  type       ExpenseType
  paidMethod ExpensePaidMethod @default(BANK_TRANSFER) @map("paid_method")
  notes      String?

  dayOfMonth Int       @map("day_of_month") // 1-31; 月底特例 cron 內處理
  startDate  DateTime  @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date // null = forever
  active     Boolean   @default(true)

  /// 最近一次成功生成 Expense 的日期，用來防止 cron 重複建立
  lastMaterialisedAt DateTime? @map("last_materialised_at") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  expenses Expense[]

  @@index([tenantId, active, dayOfMonth])
  @@map("expense_recurring_rules")
}

enum ExpenseType {
  FIXED // 房租、水電、保險（每月相對固定）
  VARIABLE // 耗材、補貨、修理（金額不定）
}

enum ExpensePaidMethod {
  CASH
  BANK_TRANSFER
}

// ============================================
// V3.7 — DAILY CLOSE SNAPSHOT (每日結帳對帳記錄)
// ============================================

/// V3.7 §3 — frozen snapshot per closed business day. Source of truth for
/// "5/2 已結帳 23:14" UI + monthly view colour coding + 異常分析。
model DailyCloseSnapshot {
  id       String   @id @default(uuid())
  tenantId String   @map("tenant_id")
  date     DateTime @db.Date

  /// 系統自動算的數字（rebuild safe, idempotent）
  expectedCash Int @map("expected_cash") // 現金預約 - 現金支出
  expectedBank Int @map("expected_bank") // 轉帳預約 - 轉帳支出

  /// 老闆送出時親自確認的數字
  actualCash    Int     @map("actual_cash")
  cashDiff      Int     @map("cash_diff") // actual - expected
  bankConfirmed Boolean @default(false) @map("bank_confirmed")

  /// 結帳當下的明細數量（純展示用）
  bookingCount Int @map("booking_count")
  expenseCount Int @map("expense_count")
  totalRevenue Int @map("total_revenue")
  totalExpense Int @map("total_expense")
  netProfit    Int @map("net_profit")

  notes String? // 差異備註（差異 != 0 時必填）

  closedAt  DateTime @default(now()) @map("closed_at")
  closedBy  String?  @map("closed_by") // adminUserId
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId, closedAt])
  @@map("daily_close_snapshots")
}

/// V3.8 P0 prevention (5/1 incident): 攔截所有 destructive ops
/// (deleteMany / updateMany / executeRaw / executeRawUnsafe) 寫進 audit log。
/// 下次資料異常時可立刻查「誰幾點刪了什麼」。
///
/// Executor 來源：env var EXECUTED_BY，未設則記 'unknown'。
/// 所有 admin script 跑前該 export EXECUTED_BY=ryan-2026-05-03-import 之類 ID。
model AuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())

  /// "Booking" / "User" / "Payment" / "$executeRaw" / etc
  model String

  /// "deleteMany" / "updateMany" / "$executeRaw" / "$executeRawUnsafe"
  action String

  /// rows affected (deleteMany.count / updateMany.count / executeRaw return)
  count Int

  /// process.env.EXECUTED_BY ?? 'unknown'（手動 script）
  /// 對 web request 是 admin name + IP（之後可加）
  executor String

  /// JSON-stringified args (filter conditions, set values etc)
  /// truncated to 4KB to avoid PG row size issues
  args Json?

  /// duration in ms (sanity check：3 秒砍 1614 筆 != 正常用法)
  durationMs Int? @map("duration_ms")

  /// 'success' / 'error: <message>'
  status String @default("success")

  @@index([timestamp])
  @@index([model, action])
  @@index([executor])
  @@map("audit_logs")
}
